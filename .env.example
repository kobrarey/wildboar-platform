# =========================
# Wild Boar - example config
# =========================

# --- app / runtime ---
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8000
UVICORN_PROXY_HEADERS=True
UVICORN_FORWARDED_ALLOW_IPS=127.0.0.1

# --- database ---
DATABASE_URL=postgresql://wildboar_user:strong_password@127.0.0.1:5432/wildboar_platform

# --- security / sessions ---
SECRET_KEY=replace_me_with_long_random_secret
COOKIE_NAME=session_id
COOKIE_SECURE=True
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/
SESSION_TTL_DAYS=30

# --- wallet encryption ---
WALLET_ENC_KEY=replace_me_with_fernet_key

# --- email / smtp relay ---
EMAIL_PROVIDER=smtp_relay
EMAIL_FROM_NAME=Wild Boar
EMAIL_FROM_EMAIL=notification@wildboar.finance

SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=True
SMTP_SSL=False
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TIMEOUT_SEC=20

# --- Gmail API fallback for local dev only ---
# EMAIL_PROVIDER=gmail_api

# --- security codes ---
SECURITY_CODE_LENGTH=6
SECURITY_CODE_TTL_MINUTES=15
SECURITY_CODE_MAX_ATTEMPTS=5
SECURITY_CODE_RESEND_COOLDOWN_SECONDS=60

# --- BSC / USDT ---
BSC_RPC_URL=https://your-quicknode-https-url
BSC_WS_URL=wss://your-quicknode-wss-url
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSC_USDT_DECIMALS=18
BSC_CONFIRMATIONS=20
BSC_CONFIRM_POLL_SEC=15
BSC_BALANCE_POLL_SEC=15
BSC_WALLET_MAP_RELOAD_SEC=60
BSC_REORG_BUFFER_BLOCKS=20
BSC_BACKFILL_CHUNK_BLOCKS=2000
BSC_START_LOOKBACK_BLOCKS=50000
BSC_BACKFILL_ON_START=True

# --- compliance ---
CHAINALYSIS_SANCTIONS_API_KEY=
COMPLIANCE_USE_CHAINALYSIS_API=True
COMPLIANCE_USE_ORACLE=True
COMPLIANCE_USE_OFAC=True
COMPLIANCE_FAIL_CLOSED=True
COMPLIANCE_HTTP_TIMEOUT_SEC=10
COMPLIANCE_POLL_SEC=10
COMPLIANCE_PENDING_RETRY_SEC=60
COMPLIANCE_ORACLE_CONTRACT=0x40C57923924B5c5c5455c48D93317139ADDaC8fb
COMPLIANCE_OFAC_FILE=data/ofac_addresses.json

# --- withdrawals ---
FEE_WALLET_OK_ADDRESS=
FEE_WALLET_OK_PRIVATE_KEY=
FEE_WALLET_BLOCKED_ADDRESS=
FEE_WALLET_BLOCKED_PRIVATE_KEY=
WITHDRAW_FEE_USDT=1
WITHDRAW_SESSION_TTL_MIN=15
WITHDRAW_GAS_BUFFER_MULT=1.2
WITHDRAW_GAS_MAX_BNB=0.01
ERC20_TRANSFER_GAS_FALLBACK=70000

# --- telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BNB_ALERT_THRESHOLD_USD=100
TELEGRAM_CHECK_SEC=3600

# --- pancake quote ---
PANCAKE_ROUTER_V2=
WBNB_ADDRESS=
USDT_BSC_ADDRESS=

# --- Stage 18.1: local navcalc ---
BYBIT_NAV_HTTP_TIMEOUT_SEC=30
BYBIT_NAV_RETRIES=4
BYBIT_NAV_BACKOFF_SEC=0.8
BYBIT_NAV_RECV_WINDOW_MS=5000
BYBIT_NAV_EQUITY_TOL_PCT=0.5
NAV_POLL_INTERVAL_SEC=10

FUND_BTC_FUND_ENABLED=true
FUND_BTC_FUND_COLLECT_NAV=true
FUND_BTC_FUND_COLLECT_BREAKDOWN=false
FUND_BTC_FUND_BYBIT_API_KEY=
FUND_BTC_FUND_BYBIT_API_SECRET=
FUND_BTC_FUND_BYBIT_TESTNET=false

FUND_DEFI_SNIPER_ENABLED=true
FUND_DEFI_SNIPER_COLLECT_NAV=true
FUND_DEFI_SNIPER_COLLECT_BREAKDOWN=false
FUND_DEFI_SNIPER_BYBIT_API_KEY=
FUND_DEFI_SNIPER_BYBIT_API_SECRET=
FUND_DEFI_SNIPER_BYBIT_TESTNET=false

FUND_WB10_ENABLED=true
FUND_WB10_COLLECT_NAV=true
FUND_WB10_COLLECT_BREAKDOWN=false
FUND_WB10_BYBIT_API_KEY=
FUND_WB10_BYBIT_API_SECRET=
FUND_WB10_BYBIT_TESTNET=false

FUND_WB_TEST_ENABLED=true
FUND_WB_TEST_COLLECT_NAV=true
FUND_WB_TEST_COLLECT_BREAKDOWN=false
FUND_WB_TEST_BYBIT_API_KEY=
FUND_WB_TEST_BYBIT_API_SECRET=
FUND_WB_TEST_BYBIT_TESTNET=false

FUND_WB_DEFI_ENABLED=false
FUND_WB_DEFI_COLLECT_NAV=true
FUND_WB_DEFI_COLLECT_BREAKDOWN=false
FUND_WB_DEFI_BYBIT_API_KEY=
FUND_WB_DEFI_BYBIT_API_SECRET=
FUND_WB_DEFI_BYBIT_TESTNET=false

FUND_WB_WEB3_ENABLED=false
FUND_WB_WEB3_COLLECT_NAV=true
FUND_WB_WEB3_COLLECT_BREAKDOWN=false
FUND_WB_WEB3_BYBIT_API_KEY=
FUND_WB_WEB3_BYBIT_API_SECRET=
FUND_WB_WEB3_BYBIT_TESTNET=false