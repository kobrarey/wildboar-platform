# =========================
# Wild Boar - example config
# =========================

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/wildboar_platform

# --- Security / sessions ---
SECRET_KEY=replace_me_with_long_random_secret

# --- Wallet encryption (Fernet key) ---
WALLET_ENC_KEY=replace_me_with_fernet_key

# --- Email provider ---
EMAIL_PROVIDER=gmail_api
EMAIL_FROM_NAME=Wild Boar
EMAIL_FROM_EMAIL=replace_me@gmail.com

# Gmail API credentials are stored locally (token.json/credentials.json), not in env.

# --- BSC / USDT deposit pipeline ---
BSC_RPC_URL=https://your-quicknode-https-url
BSC_WS_URL=wss://your-quicknode-wss-url

BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSC_USDT_DECIMALS=18

BSC_CONFIRMATIONS=20
BSC_CONFIRM_POLL_SEC=15
BSC_BALANCE_POLL_SEC=15
BSC_WALLET_MAP_RELOAD_SEC=60

# --- Compliance / sanctions screening ---
CHAINALYSIS_SANCTIONS_API_KEY=
COMPLIANCE_USE_CHAINALYSIS_API=True
COMPLIANCE_USE_ORACLE=True
COMPLIANCE_USE_OFAC=True
COMPLIANCE_FAIL_CLOSED=True
COMPLIANCE_HTTP_TIMEOUT_SEC=10
COMPLIANCE_POLL_SEC=10
COMPLIANCE_ORACLE_CONTRACT=0x40C57923924B5c5c5455c48D93317139ADDaC8fb
COMPLIANCE_OFAC_FILE=data/ofac_addresses.json