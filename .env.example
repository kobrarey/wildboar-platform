# =========================
# Wild Boar - example config
# =========================

# --- app / runtime ---
APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8000
UVICORN_PROXY_HEADERS=True
UVICORN_FORWARDED_ALLOW_IPS=127.0.0.1

# --- database ---
DATABASE_URL=postgresql://wildboar_user:strong_password@127.0.0.1:5432/wildboar_platform

# --- security / sessions ---
SECRET_KEY=replace_me_with_long_random_secret
COOKIE_NAME=session_id
COOKIE_SECURE=True
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=
COOKIE_PATH=/
SESSION_TTL_DAYS=30

# --- wallet encryption ---
WALLET_ENC_KEY=replace_me_with_fernet_key

# --- TOTP / Google Authenticator encryption ---
TOTP_ENC_KEY=replace_me_with_separate_fernet_key

# --- email / smtp relay ---
EMAIL_PROVIDER=smtp_relay
EMAIL_FROM_NAME=Wild Boar
EMAIL_FROM_EMAIL=notification@wildboar.finance

SMTP_HOST=smtp-relay.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=True
SMTP_SSL=False
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TIMEOUT_SEC=20

# --- Gmail API fallback for local dev only ---
# EMAIL_PROVIDER=gmail_api

# --- security codes ---
SECURITY_CODE_LENGTH=6
SECURITY_CODE_TTL_MINUTES=15
SECURITY_CODE_MAX_ATTEMPTS=5
SECURITY_CODE_RESEND_COOLDOWN_SECONDS=60

# --- BSC / USDT ---
BSC_RPC_URL=https://your-quicknode-https-url
BSC_WS_URL=wss://your-quicknode-wss-url
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSC_USDT_DECIMALS=18
BSC_CONFIRMATIONS=20
BSC_CONFIRM_POLL_SEC=15
BSC_BALANCE_POLL_SEC=15
BSC_WALLET_MAP_RELOAD_SEC=60
BSC_REORG_BUFFER_BLOCKS=20
BSC_BACKFILL_CHUNK_BLOCKS=2000
BSC_START_LOOKBACK_BLOCKS=50000
BSC_BACKFILL_ON_START=True

# --- compliance ---
CHAINALYSIS_SANCTIONS_API_KEY=
COMPLIANCE_USE_CHAINALYSIS_API=True
COMPLIANCE_USE_ORACLE=True
COMPLIANCE_USE_OFAC=True
COMPLIANCE_FAIL_CLOSED=True
COMPLIANCE_HTTP_TIMEOUT_SEC=10
COMPLIANCE_POLL_SEC=10
COMPLIANCE_PENDING_RETRY_SEC=60
COMPLIANCE_ORACLE_CONTRACT=0x40C57923924B5c5c5455c48D93317139ADDaC8fb
COMPLIANCE_OFAC_FILE=data/ofac_addresses.json

# --- withdrawals ---
FEE_WALLET_OK_ADDRESS=
FEE_WALLET_OK_PRIVATE_KEY=
FEE_WALLET_BLOCKED_ADDRESS=
FEE_WALLET_BLOCKED_PRIVATE_KEY=
WITHDRAW_FEE_USDT=1
WITHDRAW_SESSION_TTL_MIN=15
WITHDRAW_GAS_BUFFER_MULT=1.2
WITHDRAW_GAS_MAX_BNB=0.01
ERC20_TRANSFER_GAS_FALLBACK=70000

# --- telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
BNB_ALERT_THRESHOLD_USD=100
TELEGRAM_CHECK_SEC=3600

# --- stage 22.7: Telegram operator actions ---
# Local/default policy:
# - disabled by default;
# - Telegram callback does not execute shell;
# - Telegram callback does not execute BSC transfers;
# - Telegram callback only creates/activates DB operator action;
# - worker later reads pending action and reruns the same settlement gas top-up algorithm.
TELEGRAM_OPERATOR_ACTIONS_ENABLED=false
TELEGRAM_OPERATOR_ALLOWED_CHAT_IDS=
TELEGRAM_OPERATOR_ALLOWED_USER_IDS=
TELEGRAM_CALLBACK_SECRET=generate_long_random_secret
TELEGRAM_OPERATOR_ACTION_TTL_MINUTES=60
TELEGRAM_OPERATOR_ACTION_COOLDOWN_SEC=30

# --- stage 23.1: negative-net target calculation ---
# Mock/local only at Stage 23.1. No real Bybit fee endpoint call.
NEGATIVE_NET_MOCK_BYBIT_WITHDRAWAL_FEE_USDT=1

# --- stage 23.2: negative-net sale plan ---
# Stage 23.2 is mock/local only by default. No real Bybit calls.
NEGATIVE_NET_SALE_PLAN_MOCK_ONLY=true
NEGATIVE_NET_EXTRA_LARGEST_ASSET_BUFFER_PCT=0.10
NEGATIVE_NET_SALE_PLAN_USE_READONLY_BYBIT=false

# --- stage 23.3: negative-net sale execution ---
# Stage 23.3 is mock/local only. No real Bybit calls, trades, strategy orders, transfers, withdrawals, BSC or accounting finalization.
NEGATIVE_NET_SALE_EXECUTION_MOCK_ONLY=true
NEGATIVE_NET_SALE_FILL_ACCEPTANCE_PCT=98
NEGATIVE_NET_SALE_CORRIDOR_PCT=1
NEGATIVE_NET_SALE_SLICES=10
NEGATIVE_NET_SALE_MAX_ACTIVE_STRATEGY_ORDERS=5
NEGATIVE_NET_SALE_ALLOW_LIVE_EXECUTION=false

# --- fee wallet daily USDT -> BNB swap ---
FEE_WALLET_SWAP_ENABLED=True
FEE_WALLET_SWAP_INTERVAL_SEC=3600
FEE_WALLET_SWAP_MIN_USDT=10
FEE_WALLET_SWAP_SLIPPAGE_BPS=100
FEE_WALLET_SWAP_DAILY_HOUR_UTC=0

# --- pancake quote ---
PANCAKE_ROUTER_V2=
WBNB_ADDRESS=
USDT_BSC_ADDRESS=


# --- stage 18.3: NAV Guard ---
NAV_GUARD_ENABLED=True
NAV_GUARD_MAX_NAV_DROP_PCT=15
NAV_GUARD_EARN_DROP_PCT=50
NAV_GUARD_COMPENSATION_RATIO=0.70
NAV_GUARD_MIN_EARN_DROP_USD=10
NAV_GUARD_TELEGRAM_ALERTS=True

# --- Navcalc runtime ---
BYBIT_NAV_HTTP_TIMEOUT_SEC=30
BYBIT_NAV_RETRIES=4
BYBIT_NAV_BACKOFF_SEC=0.8
BYBIT_NAV_RECV_WINDOW_MS=5000
BYBIT_NAV_EQUITY_TOL_PCT=0.5
NAV_POLL_INTERVAL_SEC=10

# --- stage 21: settlement ---
SETTLEMENT_ENABLED=false
SETTLEMENT_CUTOFF_HOUR_UTC=23
SETTLEMENT_CUTOFF_MINUTE_UTC=59
SETTLEMENT_RUN_HOUR_UTC=0
SETTLEMENT_RUN_MINUTE_UTC=0
SETTLEMENT_PRICE_MAX_AGE_SEC=300

SETTLEMENT_WALLET_TARGET_BNB_USD=100
SETTLEMENT_WALLET_MIN_GAS_BUFFER_MULT=1.20
SETTLEMENT_GAS_TOPUP_RETRY_HOUR_UTC=23
SETTLEMENT_GAS_TOPUP_RETRY_MINUTE_UTC=50

# --- stage 22.1: positive net settlement ---
POSITIVE_NET_SETTLEMENT_ENABLED=false
POSITIVE_NET_DEPOSIT_CONFIRM_TIMEOUT_SEC=3600
POSITIVE_NET_DEPOSIT_POLL_INTERVAL_SEC=30
POSITIVE_NET_DUST_TOLERANCE_USDT=0.01

FUND_BTC_FUND_ENABLED=true
FUND_BTC_FUND_COLLECT_NAV=true
FUND_BTC_FUND_COLLECT_BREAKDOWN=false
FUND_BTC_FUND_BYBIT_API_KEY=
FUND_BTC_FUND_BYBIT_API_SECRET=
FUND_BTC_FUND_BYBIT_TESTNET=false

FUND_DEFI_SNIPER_ENABLED=true
FUND_DEFI_SNIPER_COLLECT_NAV=true
FUND_DEFI_SNIPER_COLLECT_BREAKDOWN=false
FUND_DEFI_SNIPER_BYBIT_API_KEY=
FUND_DEFI_SNIPER_BYBIT_API_SECRET=
FUND_DEFI_SNIPER_BYBIT_TESTNET=false

FUND_WB10_ENABLED=true
FUND_WB10_COLLECT_NAV=true
FUND_WB10_COLLECT_BREAKDOWN=false
FUND_WB10_BYBIT_API_KEY=
FUND_WB10_BYBIT_API_SECRET=
FUND_WB10_BYBIT_TESTNET=false

FUND_WB_TEST_ENABLED=true
FUND_WB_TEST_COLLECT_NAV=true
FUND_WB_TEST_COLLECT_BREAKDOWN=false
FUND_WB_TEST_BYBIT_API_KEY=
FUND_WB_TEST_BYBIT_API_SECRET=
FUND_WB_TEST_BYBIT_TESTNET=false

FUND_WB_DEFI_ENABLED=false
FUND_WB_DEFI_COLLECT_NAV=true
FUND_WB_DEFI_COLLECT_BREAKDOWN=false
FUND_WB_DEFI_BYBIT_API_KEY=
FUND_WB_DEFI_BYBIT_API_SECRET=
FUND_WB_DEFI_BYBIT_TESTNET=false

FUND_WB_WEB3_ENABLED=false
FUND_WB_WEB3_COLLECT_NAV=true
FUND_WB_WEB3_COLLECT_BREAKDOWN=false
FUND_WB_WEB3_BYBIT_API_KEY=
FUND_WB_WEB3_BYBIT_API_SECRET=
FUND_WB_WEB3_BYBIT_TESTNET=false

# --- Bybit master API for settlement runtime ---
# BYBIT_MASTER_API_KEY and BYBIT_MASTER_API_SECRET are required for production settlement runtime
# when Bybit deposit confirmation uses subaccount deposit records.
#
# Security policy:
# - use a separate restricted master API key;
# - enable IP whitelist for the server static IP;
# - grant only minimal permissions required for:
#   1) subaccount deposit record read;
#   2) internal transfer, if Bybit requires master key for FUND -> UNIFIED transfer;
# - do not use the company main trading key;
# - do not commit real values;
# - add real values to server .env only after backup and immediately before enabling settlement worker.
#
# BYBIT_MASTER_API_KEY=
# BYBIT_MASTER_API_SECRET=

BYBIT_MASTER_RECV_WINDOW_MS=30000
BYBIT_MASTER_HTTP_TIMEOUT_SEC=20
BYBIT_MASTER_RETRIES=3
BYBIT_MASTER_BACKOFF_SEC=0.8

# --- Per-fund Bybit subaccount API keys ---
# Each fund must have its own API key created inside the corresponding Bybit subaccount:
# btc_fund, defi_sniper, wb10, wb_test, wb_defi, wb_web3.
#
# Requirements:
# - created inside the corresponding Bybit subaccount;
# - production server static IP whitelist enabled;
# - minimal permissions for Asset internal transfer FUND -> UNIFIED;
# - future permissions may include spot/perp/options orders and Earn operations if needed;
# - do not use the master/company trading key;
# - real key/secret are stored encrypted in fund_bybit_accounts, not in .env.example.

# --- stage 22.3: allocation execution engine ---
# Stage 22.3 local policy:
# - mocked/dry-run only;
# - no real Bybit orders;
# - no real Bybit strategy orders;
# - no Earn stake;
# - no transfers;
# - no server deploy.
ALLOCATION_EXECUTION_ENABLED=false

ALLOCATION_LIQUIDITY_CORRIDOR_PCT=1
ALLOCATION_MARKET_SLIPPAGE_PCT=1
ALLOCATION_MIN_FILL_RATIO=0.90

ALLOCATION_NATIVE_ICEBERG_ORDER_COUNT=10
ALLOCATION_MAX_ACTIVE_STRATEGY_ORDERS=5

ALLOCATION_SLICED_IOC_SLICES=10
ALLOCATION_SLICED_IOC_CHASE_BPS=10

ALLOCATION_SHORT_OPTION_LIQUIDITY_MULT=1.20

ALLOCATION_MAX_IM_RATE=0.70
ALLOCATION_MAX_MM_RATE=0.50

# --- stage 22.4: spot / earn / residual mock handlers ---
# Stage 22.4 local policy:
# - mocked/dry-run only;
# - no real Bybit trades;
# - no real Earn stake;
# - no transfers;
# - no server deploy.
ALLOCATION_SPOT_EARN_ENABLED=false
ALLOCATION_EARN_ENABLED=false
ALLOCATION_USDT_EARN_CATEGORY=FlexibleSaving
ALLOCATION_RESIDUAL_MIN_MATERIALITY_USDT=0.01
ALLOCATION_RESIDUAL_ALERT_THRESHOLD_USDT=100

# --- stage 22.5: derivatives / options mock handlers ---
# Stage 22.5 local policy:
# - mocked/dry-run only;
# - no real Bybit trades;
# - no real Strategy orders;
# - no real options/perps/futures orders;
# - no transfers;
# - no Earn stake;
# - no server deploy.
ALLOCATION_DERIVATIVES_ENABLED=false
ALLOCATION_OPTIONS_ENABLED=false
ALLOCATION_DERIVATIVE_RESIDUAL_ON_GUARD_FAIL=true

# --- stage 22.6: positive-net allocation integration / reconciliation ---
# Stage 22.6 local policy:
# - mock allocation only;
# - no real Bybit trades;
# - no real Bybit POST calls;
# - no real Strategy orders;
# - no real Earn stake;
# - no transfers;
# - no server deploy;
# - full real end-to-end tests only in Stage 24.
POSITIVE_NET_ALLOCATION_ENABLED=false
POSITIVE_NET_ALLOCATION_MOCK_ONLY=true

ALLOCATION_ALERTS_ENABLED=true
ALLOCATION_RESIDUAL_CASH_ALERT_THRESHOLD_USDT=100
ALLOCATION_FAILED_REVIEW_ALERTS=true
ALLOCATION_UNKNOWN_STATE_ALERTS=true
ALLOCATION_MARGIN_BREACH_ALERTS=true

ALLOCATION_FINALIZATION_REQUIRE_NO_ACTIVE_LEGS=true